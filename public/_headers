# Restrict iframe embedding to calnotaryclass.com only
# Direct visits to tools.calnotaryclass.com still work fine
/*.html
  Content-Security-Policy: frame-ancestors https://calnotaryclass.com https://www.calnotaryclass.com;
  X-Content-Type-Options: nosniff
  X-Frame-Options: ALLOW-FROM https://calnotaryclass.com

# API endpoints — same-origin from tools iframe, plus allow WP server-side fetch
/api/*
  Access-Control-Allow-Origin: https://calnotaryclass.com https://tools.calnotaryclass.com
  Access-Control-Allow-Methods: GET
  Access-Control-Allow-Headers: Content-Type
